# Required: Gemini API key (free tier works — get one at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_key_here

# Optional: which LLM provider to use. Default: gemini.
# Supported: gemini. Coming soon: ollama.
LLM_PROVIDER=gemini

# Optional: path on your host to mount as the notes source.
# Defaults to ./notes inside the repo.
HOST_NOTES_PATH=./notes

# Optional: Postgres URL override (default points to docker-compose db service).
# DATABASE_URL=postgresql+psycopg2://korely:korely@db:5432/korely_graphrag
